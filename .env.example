# Copy this file to `.env` and adjust values for your machine:
#     cp .env.example .env
#
# `.env` is gitignored — your local values stay on your device only.

# --- Database ---------------------------------------------------------------
# Points at the PostgreSQL started by `docker compose up db -d`.
# Credentials match docker-compose.yml (user / password / db = transitops).
# If you run Postgres some other way, change host/port/user/password/db to match.
DATABASE_URL="postgresql://transitops:transitops@localhost:5432/transitops"

# --- Auth -------------------------------------------------------------------
# Secret used to sign JWT session tokens. Use any long random string locally.
# Generate one with:  openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string"

# Set to "true" ONLY when serving over HTTPS. Leaving it unset keeps the session
# cookie usable over plain http://localhost (local dev / Docker).
# COOKIE_SECURE="true"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
