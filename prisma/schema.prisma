generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum VehicleType {
  TRUCK
  VAN
  BUS
  SEDAN
  SUV
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseType {
  TOLL
  REPAIR
  INSURANCE
  PARKING
  MAINTENANCE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                  String        @id @default(cuid())
  registrationNumber  String        @unique
  vehicleName         String
  model               String
  vehicleType         VehicleType
  maximumLoadCapacity Float
  acquisitionCost     Float
  odometer            Float         @default(0)
  status              VehicleStatus @default(AVAILABLE)
  region              String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  trips       Trip[]
  maintenance Maintenance[]
  fuelLogs    FuelLog[]
  expenses    Expense[]
}

model Driver {
  id            String       @id @default(cuid())
  name          String
  licenseNumber String       @unique
  category      String
  expiryDate    DateTime
  phone         String
  safetyScore   Float        @default(100)
  status        DriverStatus @default(AVAILABLE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  trips Trip[]
}

model Trip {
  id              String     @id @default(cuid())
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  fuelConsumed    Float?
  startTime       DateTime?
  endTime         DateTime?
  revenue         Float
  status          TripStatus @default(DRAFT)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id])

  bilty Bilty?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Maintenance {
  id          String            @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  title       String
  description String?
  cost        Float
  status      MaintenanceStatus @default(OPEN)
  openedAt    DateTime          @default(now())
  closedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  liters    Float
  cost      Float
  date      DateTime
  odometer  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String      @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  type        ExpenseType
  amount      Float
  description String?
  date        DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// === BILLING & COMPLIANCE LAYER (Phase 1: booking, parties, ledger) ===

enum PartyType {
  CONSIGNOR
  CONSIGNEE
  BOTH
}

enum BiltyStatus {
  DRAFT
  ACTIVE
  CHALLAN_DONE
  DELIVERED
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
}

// Company master — used for print headers (name, GST, address).
model Company {
  id        String   @id @default(cuid())
  name      String
  address   String
  gst       String?
  pan       String?
  phone     String
  email     String
  branch    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Consignor / consignee master with ledger relations.
model Party {
  id             String    @id @default(cuid())
  name           String
  type           PartyType @default(BOTH)
  gst            String?
  phone          String
  email          String
  address        String?
  openingBalance Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  consignorBiltys Bilty[]   @relation("consignorBiltys")
  consigneeBiltys Bilty[]   @relation("consigneeBiltys")
  payments        Payment[]
  invoices        Invoice[]
}

// Bilty (LR) — the primary booking document. Charges are auto-calculated.
model Bilty {
  id            String      @id @default(cuid())
  biltyNumber   String      @unique
  tripId        String?     @unique
  trip          Trip?       @relation(fields: [tripId], references: [id])
  consignorId   String
  consignor     Party       @relation("consignorBiltys", fields: [consignorId], references: [id])
  consigneeId   String
  consignee     Party       @relation("consigneeBiltys", fields: [consigneeId], references: [id])
  fromLocation  String
  toLocation    String
  date          DateTime    @default(now())
  goodsDesc     String
  packages      Int
  packingMethod String?
  actualWeight  Float // in KG
  chargedWeight Float // in Quintals (1 Quintal = 100kg)
  grNumber      String?
  privateMark   String?
  remarks       String?
  labourCharge  Float       @default(0) // ₹15 × chargedWeight
  grCharge      Float       @default(30) // Fixed ₹30
  doorDelivery  Float? // only if applicable
  pfCharge      Float? // Platform fee, only if another transporter
  serviceTax    Float?
  total         Float       @default(0) // labour + gr + door + pf + tax
  insurance     String      @default("Owner's Risk")
  status        BiltyStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  payments Payment[]
  invoices Invoice[]
}

// Party payment against outstanding balance.
model Payment {
  id        String      @id @default(cuid())
  partyId   String
  party     Party       @relation(fields: [partyId], references: [id])
  biltyId   String?
  bilty     Bilty?      @relation(fields: [biltyId], references: [id])
  amount    Float
  date      DateTime    @default(now())
  mode      PaymentMode
  reference String?
  createdAt DateTime    @default(now())
}

// Freight invoice generated from a Bilty.
model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  biltyId       String
  bilty         Bilty    @relation(fields: [biltyId], references: [id])
  partyId       String
  party         Party    @relation(fields: [partyId], references: [id])
  amount        Float
  generatedAt   DateTime @default(now())
  paid          Boolean  @default(false)
}

// Transaction-safe sequence counters (e.g. daily bilty numbers, challan serials).
model Counter {
  id    String @id @default(cuid())
  key   String @unique
  value Int    @default(0)
}
